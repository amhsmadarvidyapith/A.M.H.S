</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AMHS Student App</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand: #4f46e5;
            --brand-dark: #3730a3;
            --surface: #ffffff;
            --bg: #f8fafc;
            --text-title: #0f172a;
            --text-body: #64748b;
        }

        * { 
            box-sizing: border-box; 
            font-family: 'Outfit', sans-serif; 
            -webkit-tap-highlight-color: transparent; 
        }
        
        body { 
            background-color: var(--bg); 
            margin: 0; 
            padding: 0; 
            display: flex; 
            justify-content: center; 
        }

        .app-container { 
            width: 100%; 
            max-width: 500px; 
            min-height: 100vh; 
            background: var(--bg); 
            position: relative; 
            box-shadow: 0 0 50px rgba(0,0,0,0.05);
        }

        /* Top Navigation */
        .top-nav {
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--surface);
            position: sticky;
            top: 0;
            z-index: 10;
            border-bottom: 1px solid #f1f5f9;
        }

        .logo-text { font-weight: 800; font-size: 20px; color: var(--brand); letter-spacing: -0.5px; }

        .logout-pill {
            background: #fee2e2;
            color: #ef4444;
            border: none;
            padding: 8px 16px;
            border-radius: 20px;
            font-weight: 700;
            font-size: 12px;
            cursor: pointer;
            transition: 0.2s;
        }
        .logout-pill:active { transform: scale(0.95); opacity: 0.8; }

        /* Header Splash */
        .header-splash {
            background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
            padding: 40px 25px;
            color: white;
            border-radius: 0 0 30px 30px;
            margin-bottom: 25px;
            box-shadow: 0 10px 25px rgba(79, 70, 229, 0.15);
        }

        .header-splash h1 { margin: 0; font-size: 28px; font-weight: 800; letter-spacing: -0.5px; }
        
        /* Working Last Opened Badge */
        .last-opened-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 15px;
            background: rgba(255, 255, 255, 0.15);
            padding: 8px 15px;
            border-radius: 14px;
            font-size: 12px;
            font-weight: 500;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Action Grid */
        .menu-grid { 
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 15px; 
            padding: 0 20px 40px; 
        }

        .menu-item {
            background: var(--surface);
            border-radius: 24px;
            padding: 25px 20px;
            text-align: center;
            border: 1px solid #eef2f6;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
            align-items: center;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.04);
        }

        .menu-item:active { transform: scale(0.96); background: #fafafa; }

        .icon-box {
            width: 56px; height: 56px;
            background: #f1f5f9;
            border-radius: 18px;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 12px;
        }

        .icon-box svg { width: 28px; height: 28px; stroke: var(--text-title); stroke-width: 2; fill: none; }

        .menu-item span { font-weight: 700; color: var(--text-title); font-size: 15px; }

        /* Timetable Special Style */
        .item-timetable .icon-box { background: #dcfce7; }
        .item-timetable .icon-box svg { stroke: #16a34a; }

        /* Admin Style */
        .item-admin { 
            grid-column: span 2; 
            flex-direction: row !important; 
            justify-content: center; 
            gap: 15px; 
            background: #1e293b; 
            padding: 18px;
            margin-top: 10px;
            border: none;
        }
        .item-admin span { color: white; }
        .item-admin .icon-box { 
            background: rgba(255,255,255,0.1); 
            margin-bottom: 0; 
            width: 40px; 
            height: 40px; 
        }
        .item-admin .icon-box svg { stroke: white; width: 20px; height: 20px; }

        /* MODAL (Bottom Sheet) */
        .modal-overlay {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.4); backdrop-filter: blur(4px);
            justify-content: center; align-items: flex-end; z-index: 100;
        }

        .modal-content {
            background: white; width: 100%; max-width: 500px; padding: 30px;
            border-radius: 30px 30px 0 0; text-align: center;
            box-shadow: 0 -10px 25px rgba(0,0,0,0.1);
            animation: slideUp 0.3s ease-out;
        }

        @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

        .modal-action-btn {
            width: 100%; padding: 16px; border-radius: 16px; border: 1px solid #e2e8f0;
            background: #f8fafc; margin-bottom: 12px; font-weight: 700; font-size: 16px;
            color: var(--brand); cursor: pointer; transition: 0.2s;
        }
        .modal-action-btn:hover { background: var(--brand); color: white; }

        .close-link { color: var(--text-body); font-weight: 600; cursor: pointer; display: block; margin-top: 15px; font-size: 14px; }
    </style>
</head>
<body>

    <div class="app-container">
        <nav class="top-nav">
            <div class="logo-text">Adwaita Mission </div>
            <button class="logout-pill" onclick="logout()">Logout</button>
        </nav>

        <header class="header-splash">
            <h1 id="greeting-text">Welcome, <span id="display-name">Student</span>!</h1>
            <div class="last-opened-badge">
                <span>⏱️</span>
                <span id="last-opened-text">New Session Started</span>
            </div>
        </header>

        <div class="menu-grid">
            <div class="menu-item" onclick="location.href='assignments.html'">
                <div class="icon-box">
                    <svg viewBox="0 0 24 24"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <span>Assignments</span>
            </div>

            <div class="menu-item" onclick="location.href='notice.html'">
                <div class="icon-box">
                    <svg viewBox="0 0 24 24"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <span>Notices</span>
            </div>

            <div class="menu-item item-timetable" onclick="location.href='timetable.html'">
                <div class="icon-box">
                    <svg viewBox="0 0 24 24">
                        <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/>
                        <circle cx="15" cy="15" r="3" /><path d="M15 14v1l1 1" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span>Time Table</span>
            </div>

            <div class="menu-item" onclick="toggleModal(true)">
                <div class="icon-box">
                    <svg viewBox="0 0 24 24"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <span>About Us</span>
            </div>

            <div class="menu-item item-admin" onclick="location.href='admin.html'">
                <div class="icon-box">
                    <svg viewBox="0 0 24 24"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <span>Admin Settings</span>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="modalOverlay">
        <div class="modal-content">
            <h2 style="font-weight: 800; margin-top: 0; color: var(--text-title);">School Information</h2>
            <button class="modal-action-btn" onclick="location.href='founder.html'">Our Founder</button>
            <button class="modal-action-btn" onclick="location.href='inspiration.html'">Our Inspiration</button>
            <span class="close-link" onclick="toggleModal(false)">Dismiss</span>
        </div>
    </div>

    <script>
        // --- REAL-TIME FUNCTIONALITY ---
        window.onload = function() {
            // 1. Get User Data
            const name = localStorage.getItem("studentName") || "Student";
            
            // 2. Smart Greeting Based on Time
            const hours = new Date().getHours();
            let greet = "Hello";
            if (hours < 12) greet = "Good Morning";
            else if (hours < 17) greet = "Good Afternoon";
            else greet = "Good Evening";
            document.getElementById("greeting-text").innerHTML = `${greet}, <span id="display-name">${name}</span>!`;

            // 3. WORKING "LAST OPENED" LOGIC
            // Get the OLD timestamp before we update it
            const lastSession = localStorage.getItem("real_last_opened");
            if (lastSession) {
                document.getElementById("last-opened-text").innerText = "Last session: " + lastSession;
            } else {
                document.getElementById("last-opened-text").innerText = "Welcome to your first login!";
            }

            // Create and Save the NEW timestamp for the NEXT time they visit
            const now = new Date();
            const formattedTime = now.toLocaleDateString([], { day: '2-digit', month: 'short' }) + " at " + 
                                  now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: true });
            
            localStorage.setItem("real_last_opened", formattedTime);
        };

        // --- NAVIGATION & UI LOGIC ---
        function toggleModal(show) {
            document.getElementById('modalOverlay').style.display = show ? 'flex' : 'none';
        }

        function logout() {
            if (confirm("Confirm Logout? Session data will be cleared.")) {
                localStorage.clear();
                window.location.href = "index.html";
            }
        }

        // Close modal on background tap
        window.onclick = function(e) {
            if (e.target == document.getElementById('modalOverlay')) toggleModal(false);
        }
    </script>
</body>
</html>

