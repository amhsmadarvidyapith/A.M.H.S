<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Control Center - AMHS</title>
    <style>
        * { box-sizing: border-box; font-family: 'Segoe UI', Tahoma, sans-serif; }
        body { background-color: #f4f7f6; margin: 0; display: flex; height: 100vh; overflow: hidden; }
        
        /* Password Overlay */
        #admin-lock-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #2d3436; display: flex; justify-content: center; align-items: center; z-index: 9999;
        }
        .lock-box { background: white; padding: 40px; border-radius: 15px; text-align: center; width: 90%; max-width: 350px; }
        
        /* Sidebar */
        .sidebar { width: 260px; background: #2d3436; color: white; display: flex; flex-direction: column; padding: 20px; }
        .sidebar h2 { font-size: 20px; border-bottom: 2px solid #4a90e2; padding-bottom: 10px; margin-bottom: 20px; color: #4a90e2; }
        .side-btn { background: none; border: none; color: #bdc3c7; text-align: left; padding: 14px; cursor: pointer; font-size: 16px; border-radius: 8px; margin-bottom: 5px; width: 100%; }
        .side-btn:hover, .side-btn.active { color: white; background: #4a90e2; }

        /* Content Area */
        .main-content { flex: 1; padding: 30px; overflow-y: auto; background: #fdfdfd; }
        .section { display: none; max-width: 800px; margin: 0 auto; animation: fadeIn 0.3s ease; }
        .section.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .card { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); margin-bottom: 20px; }
        h3 { margin-top: 0; color: #2d3436; border-bottom: 1px solid #eee; padding-bottom: 10px; }
        
        input, select, textarea { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; margin-top: 8px; }
        .btn-save { background: #00b894; color: white; border: none; padding: 15px; border-radius: 8px; cursor: pointer; width: 100%; font-weight: bold; margin-top: 15px; }
        
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { text-align: left; padding: 12px; border-bottom: 1px solid #eee; }
        .delete-btn { background: #ff4d4d; color: white; border: none; padding: 6px 12px; border-radius: 5px; cursor: pointer; }
        
        .day-selector { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; background: #f8f9fa; padding: 15px; border-radius: 8px; }
    </style>
</head>
<body>

    <div id="admin-lock-screen">
        <div class="lock-box">
            <h2>Admin Access</h2>
            <input type="password" id="adminPassInput" placeholder="Enter Password">
            <button class="btn-save" onclick="verifyAdminPass()">Unlock</button>
            <p id="error-msg" style="color: red; display: none; margin-top: 10px;">Incorrect Password!</p>
        </div>
    </div>

    <div class="sidebar">
        <h2>Admin Panel</h2>
        <button class="side-btn active" onclick="showSection('students-sec')">View Students</button>
        <button class="side-btn" onclick="showSection('timetable-sec')">Manage Timetable</button>
        <button class="side-btn" onclick="showSection('notice-sec')">Notices & Deletion</button>
        <button class="side-btn" onclick="showSection('homework-sec')">Assign Homework</button>
        <a href="main.html" style="color: #ff7675; text-align: center; margin-top: auto; text-decoration: none;">← Exit Admin</a>
    </div>

    <div class="main-content">
        
        <div id="students-sec" class="section active">
            <div class="card">
                <h3>Registered Students</h3>
                <table>
                    <thead><tr><th>Adm No</th><th>Name</th><th>Class</th><th>Action</th></tr></thead>
                    <tbody id="studentBody"></tbody>
                </table>
            </div>
        </div>

        <div id="timetable-sec" class="section">
            <div class="card">
                <h3>Add Timetable Entry</h3>
                <form id="timetableForm">
                    <input type="number" id="tt-class" placeholder="Class (e.g. 8)" required>
                    <input type="text" id="tt-section" placeholder="Section (e.g. A)" maxlength="1" required>
                    <select id="tt-period"><option value="1">1st Period</option><option value="2">2nd Period</option><option value="3">3rd Period</option></select>
                    <input type="text" id="tt-teacher" placeholder="Teacher Name" required>
                    <input type="text" id="tt-subject" placeholder="Subject" required>
                    <div class="day-selector" style="margin-top:10px;">
                        <label><input type="checkbox" name="days" value="Monday"> Mon</label>
                        <label><input type="checkbox" name="days" value="Tuesday"> Tue</label>
                        <label><input type="checkbox" name="days" value="Wednesday"> Wed</label>
                    </div>
                    <button type="submit" id="ttSaveBtn" class="btn-save">Save to Timetable</button>
                </form>
            </div>
        </div>

        <div id="notice-sec" class="section">
            <div class="card">
                <h3>Post New Notice</h3>
                <form id="noticeForm">
                    <input type="text" id="notice-title" placeholder="Notice Title" required>
                    <textarea id="notice-msg" placeholder="Message Details..." required></textarea>
                    <button type="submit" id="noticeSaveBtn" class="btn-save">Publish Notice</button>
                </form>
            </div>
            <div class="card">
                <h3>Active Notices (Delete Old Ones)</h3>
                <table>
                    <thead><tr><th>Date</th><th>Title</th><th>Action</th></tr></thead>
                    <tbody id="noticeTableBody"></tbody>
                </table>
            </div>
        </div>

        <div id="homework-sec" class="section">
            <div class="card">
                <h3>Assign Homework</h3>
                <form id="homeworkForm">
                    <input type="number" id="hw-class" placeholder="Class" required>
                    <input type="text" id="hw-section" placeholder="Section" required>
                    <input type="text" id="hw-subject" placeholder="Subject" required>
                    <textarea id="hw-details" placeholder="Homework Description..." required></textarea>
                    <button type="submit" id="hwSaveBtn" class="btn-save">Assign Homework</button>
                </form>
            </div>
        </div>

    </div>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/12.12.1/firebase-app.js";
    import { getFirestore, collection, getDocs, setDoc, addDoc, doc, deleteDoc, query, orderBy, serverTimestamp } from "https://www.gstatic.com/firebasejs/12.12.1/firebase-firestore.js";

    const firebaseConfig = {
        apiKey: "AIzaSyBhB6Bc29g-sZCV9MLu_jQCD5GdlhL2mgM",
        authDomain: "amhs-e7f6d.firebaseapp.com",
        projectId: "amhs-e7f6d",
        storageBucket: "amhs-e7f6d.firebasestorage.app",
        messagingSenderId: "226999110651",
        appId: "1:226999110651:web:3746238cb0140f1897d95e"
    };

    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);

    // --- 1. NAVIGATION & PASSWORD ---
    window.verifyAdminPass = () => {
        const pass = document.getElementById('adminPassInput').value;
        if(pass === "admin@amhs") {
            document.getElementById('admin-lock-screen').style.display = 'none';
            loadStudents(); // Load first screen data
        } else {
            document.getElementById('error-msg').style.display = 'block';
        }
    };

    window.showSection = (id) => {
        document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
        document.querySelectorAll('.side-btn').forEach(b => b.classList.remove('active'));
        
        const activeBtn = Array.from(document.querySelectorAll('.side-btn')).find(btn => btn.getAttribute('onclick').includes(id));
        if(activeBtn) activeBtn.classList.add('active');
        
        document.getElementById(id).classList.add('active');

        // Trigger data loads
        if (id === 'students-sec') loadStudents();
        if (id === 'notice-sec') loadAdminNotices();
    };

    // --- 2. STUDENT MANAGEMENT ---
    async function loadStudents() {
        const body = document.getElementById('studentBody');
        body.innerHTML = "<tr><td colspan='4'>Loading Students...</td></tr>";
        try {
            const snap = await getDocs(collection(db, "students"));
            body.innerHTML = "";
            snap.forEach(r => {
                const d = r.data();
                body.innerHTML += `<tr>
                    <td>${d.admissionNo}</td>
                    <td>${d.studentName}</td>
                    <td>${d.class}-${d.section}</td>
                    <td><button class="delete-btn" onclick="deleteItem('students','${r.id}', 'student')">Del</button></td>
                </tr>`;
            });
        } catch (e) { body.innerHTML = "Error loading students."; }
    }

    // --- 3. NOTICE MANAGEMENT ---
    async function loadAdminNotices() {
        const body = document.getElementById('noticeTableBody');
        body.innerHTML = "<tr><td colspan='3'>Loading Notices...</td></tr>";
        try {
            const q = query(collection(db, "notices"), orderBy("timestamp", "desc"));
            const snap = await getDocs(q);
            body.innerHTML = "";
            snap.forEach(r => {
                const d = r.data();
                const date = d.timestamp ? d.timestamp.toDate().toLocaleDateString() : "Just now";
                body.innerHTML += `<tr>
                    <td>${date}</td>
                    <td>${d.title}</td>
                    <td><button class="delete-btn" onclick="deleteItem('notices','${r.id}', 'notice')">Delete</button></td>
                </tr>`;
            });
        } catch (e) { body.innerHTML = "Error loading notices."; }
    }

    // --- 4. SHARED DELETE FUNCTION ---
    window.deleteItem = async (coll, id, type) => {
        if(confirm(`Are you sure you want to delete this ${type}?`)) {
            try {
                await deleteDoc(doc(db, coll, id));
                if(type === 'student') loadStudents();
                if(type === 'notice') loadAdminNotices();
            } catch (e) { alert("Delete failed: " + e.message); }
        }
    };

    // --- 5. SUBMISSION LOGIC ---
    document.getElementById('noticeForm').onsubmit = async (e) => {
        e.preventDefault();
        await addDoc(collection(db, "notices"), { 
            title: document.getElementById('notice-title').value, 
            message: document.getElementById('notice-msg').value, 
            timestamp: serverTimestamp() 
        });
        alert("Notice Published!"); e.target.reset(); loadAdminNotices();
    };

    document.getElementById('homeworkForm').onsubmit = async (e) => {
        e.preventDefault();
        await addDoc(collection(db, "homeworks"), { 
            class: document.getElementById('hw-class').value, 
            section: document.getElementById('hw-section').value.toUpperCase(),
            subject: document.getElementById('hw-subject').value,
            details: document.getElementById('hw-details').value,
            timestamp: serverTimestamp() 
        });
        alert("Homework Assigned!"); e.target.reset();
    };

    document.getElementById('timetableForm').onsubmit = async (e) => {
        e.preventDefault();
        const days = [...document.querySelectorAll('input[name="days"]:checked')].map(c => c.value);
        const p = document.getElementById('tt-period').value;
        const cls = document.getElementById('tt-class').value;
        const sec = document.getElementById('tt-section').value.toUpperCase();
        for(const day of days) {
            await setDoc(doc(db, "timetable", `${cls}${sec}-${day}-P${p}`), {
                class: cls, section: sec, day: day, period: p, 
                teacher: document.getElementById('tt-teacher').value, 
                subject: document.getElementById('tt-subject').value
            });
        }
        alert("Timetable Saved!"); e.target.reset();
    };
</script>

</body>
</html>
